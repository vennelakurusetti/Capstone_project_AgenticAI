# ============================================================
# Compliance Advisory & Triage Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# .env is gitignored — never commit it.
# On Render, set these as Environment Variables in the dashboard.
# ============================================================

# ── Required ────────────────────────────────────────────────────
# Your OpenRouter API key. Get one at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Optional — LLM model ────────────────────────────────────────
# Default: mistralai/mistral-7b-instruct
# Any OpenRouter-compatible model slug works here.
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# ── Optional — Paths (defaults shown) ──────────────────────────
# Override only if you move files out of the standard layout.
# CHROMA_PERSIST_DIR=./data/chroma_db
# POLICIES_DIR=./data/policies
# AUDIT_LOG_PATH=./logs/audit.json

# ── Optional — Retrieval tuning ────────────────────────────────
# RETRIEVAL_TOP_K=5
# SIMILARITY_MIN_SCORE=0.10
# CONFIDENCE_THRESHOLD=0.65
